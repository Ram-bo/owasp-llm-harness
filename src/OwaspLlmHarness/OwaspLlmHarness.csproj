<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
  </PropertyGroup>

  <ItemGroup>
    <!--
      Semantic Kernel. SK moves fast: in some 1.x versions the Azure OpenAI
      connector lives in a separate package, Microsoft.SemanticKernel.Connectors.AzureOpenAI,
      with namespace Microsoft.SemanticKernel.Connectors.AzureOpenAI. If the build
      cannot find AddAzureOpenAIChatCompletion, add that package and adjust the
      using in SemanticKernelChatModel.cs. Pin to a specific version for reproducible CI.
    -->
    <PackageReference Include="Microsoft.SemanticKernel" Version="1.*" />
  </ItemGroup>

</Project>
